---
import { WHATSAPP_HREF } from '../consts';

interface Props {
  source: string;
  variant?: 'solid' | 'outline' | 'gold' | 'light';
  size?: 'default' | 'compact';
  showIcon?: boolean;
  fullWidth?: boolean;
}

const {
  source,
  variant = 'solid',
  size = 'default',
  showIcon = false,
  fullWidth = false,
} = Astro.props;
---

<a
  href={WHATSAPP_HREF}
  class:list={[
    'wa-link',
    `wa-link--${variant}`,
    `wa-link--${size}`,
    { 'wa-link--full': fullWidth },
  ]}
  onclick={`window.trackWhatsAppClick('${source}')`}
>
  {
    showIcon && (
      <svg width="19" height="19" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.872.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.464 3.488" />
      </svg>
    )
  }
  <slot />
</a>

<style>
  .wa-link {
    display: inline-flex;
    align-items: center;
    gap: 11px;
    font-weight: 600;
    border-radius: 6px;
    letter-spacing: 0.01em;
    transition:
      background 0.2s ease,
      color 0.2s ease,
      border-color 0.2s ease;
  }

  .wa-link--solid {
    background: var(--color-ink);
    color: var(--color-bg);
    font-size: 16px;
    padding: 17px 30px;
  }
  .wa-link--solid:hover {
    background: var(--color-navy);
    color: var(--color-bg);
  }

  .wa-link--outline {
    background: transparent;
    color: #fff;
    font-size: 15px;
    padding: 15px 28px;
    border: 1px solid rgba(195, 165, 98, 0.65);
  }
  .wa-link--outline:hover {
    background: var(--color-gold);
    color: var(--color-ink);
    border-color: var(--color-gold);
  }

  .wa-link--gold {
    background: var(--color-gold);
    color: var(--color-ink);
    font-size: 15px;
    padding: 15px 30px;
  }
  .wa-link--gold:hover {
    background: #b09251cc;
  }

  .wa-link--light {
    background: var(--color-bg);
    color: var(--color-ink);
    font-weight: 700;
    font-size: clamp(16px, 2vw, 18px);
    padding: 19px 38px;
    border-radius: 7px;
  }
  .wa-link--light:hover {
    background: var(--color-gold);
    color: var(--color-ink);
  }

  .wa-link--full {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  .wa-link--compact {
    font-size: 14.5px;
    padding: 14px;
  }
</style>
